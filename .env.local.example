# Copy this file to .env.local and fill in your values
# Also add these as Environment Variables in your Vercel project settings

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/SHEET_ID_IS_HERE/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# The name of the tab/sheet inside your spreadsheet (default is "Sheet1")
GOOGLE_SHEET_TAB=Sheet1

# From your Google Service Account JSON file
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# The private key from your service account JSON — paste the full value including -----BEGIN...END-----
# In Vercel, paste as-is. In .env.local, wrap in double quotes.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
